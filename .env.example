# Public origin of the deployed site (no trailing slash), used for SEO
# metadata, Open Graph, JSON-LD, sitemap.xml and robots.txt.
# e.g. https://almaprep.conyso.com — falls back to the default in src/lib/siteConfig.ts if unset.
NEXT_PUBLIC_SITE_URL=

# Where the /contact-sales form submits. Set to a Formspree (or similar) form URL
# connected to the Almaprep inbox/Gmail. If left blank, the form falls back to
# opening the visitor's email client pre-filled to partnerships@almaprep.app.
NEXT_PUBLIC_CONTACT_ENDPOINT=

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
INTERVIEW_GROQ_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Rate limiting (Upstash Redis) ────────────────────────────────────────────
# Makes API rate limits authoritative across serverless invocations. Without
# these, the limiter falls back to per-instance in-memory (fine for local dev,
# NOT effective on Vercel/serverless). Create a free DB at upstash.com.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Product analytics (PostHog) ──────────────────────────────────────────────
# Funnel/conversion tracking. Absent = analytics is a no-op. Free tier at posthog.com.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ── Error monitoring (Sentry) ────────────────────────────────────────────────
# Absent DSN = Sentry is a no-op. NEXT_PUBLIC_SENTRY_DSN covers browser + server;
# only set SENTRY_DSN if you want a different server-side project. From sentry.io.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
